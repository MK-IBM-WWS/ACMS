У меня есть база данных acms (СКУД) написанная на Postgresql со следующей структурой: CREATE TABLE IF NOT EXISTS departments(
	department_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	department_name text NOT NULL,
	address text NOT NULL,
	chief_fio text,
	activity_type text
);
ALTER TABLE departments ADD CONSTRAINT unique_department UNIQUE (department_name, address);
CREATE TABLE IF NOT EXISTS staff(
	staff_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	fio text NOT NULL,
    phone text NOT NULL UNIQUE,
	position_name text,
	is_work boolean NOT NULL DEFAULT False,
	department_id int NOT NULL REFERENCES departments(department_id)
);
CREATE TABLE IF NOT EXISTS pass(
	pass_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	issue_date date NOT NULL,
	expiration_date date NOT NULL DEFAULT CURRENT_DATE,
	staff_id int NOT NULL REFERENCES staff(staff_id),
	pass_department_id int NOT NULL REFERENCES departments(department_id)
);
CREATE TABLE IF NOT EXISTS access_groups(
	group_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	group_name text NOT NULL UNIQUE,
	change_date date NOT NULL
);
CREATE TABLE IF NOT EXISTS purpose(
	purpose_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	issue_date date NOT NULL,
	expiration_date date NOT NULL DEFAULT CURRENT_DATE,
	pass_id int NOT NULL REFERENCES pass(pass_id),
	group_id int NOT NULL REFERENCES access_groups(group_id)
);
CREATE TABLE IF NOT EXISTS access_controller(
	controller_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	object_name text NOT NULL,
	address text,
	work_shedule text,
	network_address text NOT NULL,
	model text,
	status text NOT NULL CHECK (status IN('Online', 'Offline','Restarting')) DEFAULT 'Offline'
);
ALTER TABLE access_controller ADD CONSTRAINT unique_object_address UNIQUE (object_name, address);
CREATE TABLE IF NOT EXISTS group_consists(
	position_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	controller_id int NOT NULL REFERENCES access_controller(controller_id),
	group_id int NOT NULL REFERENCES access_groups(group_id)
);
CREATE TABLE IF NOT EXISTS access_facts(
	access_id int PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
	solution text NOT NULL CHECK (solution IN('Rejected', 'Accepted','Pending')) DEFAULT 'Pending',
	access_time timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
	access_type text NOT NULL CHECK (access_type IN('IN', 'OUT')),
	pass_id int NOT NULL REFERENCES pass(pass_id),
	controller_id int NOT NULL REFERENCES access_controller(controller_id)
); Я сделал вот такое окно для добавления сотрудника отдела пользователем HR на qt6 под c++, мне нужно, чтобы в этом окне можно было вносить новые записи в таблицу staff, для этого необходимо сразу при открытии окна подключиться к бд по данным из конфига (для работы с конфигом написан следующий класс: class DbConfig
{public: DbConfig(); QString host; int port; void loadConfig(); //загрузка конфига из файла}; - этот класс тебе писать не надо, я его уже сделал), логин и пароль подкючения к бд передаются при открытии окна. В llogin необходимо отобразить переданный логин подключения к бд. В поле lefio вносится фио сотрудника, в поле lephone вносится номер телефона сотрудника, в комбобокс cbiswork вносится булевое значение True/Fase, при это если значение истина должно отображаться "Работает", иначе "Уволен", в поле leposition вносится название должности сотрудника, в поле ledepo вносится название отдела, в котором работает сотрудник и адрес отдела чеерез разделитель | в процессе ввода должна выводиться подсказка повводу названия отдела с возможностью автодополнения, потом по внесенным данным выводится id отдела, после нажатия на кнопку btnadd запись добавляется в бд и эти поля очищаются.   После нажатия на кнопку btnlogout открывается (если не открыто) окно HrWindow(QString &login, QString &password, QWidget *parent = nullptr); куда передаются значения логина и пароля подключения к бд, и закрывается окно добавления сотрудника. Вот .ui файл окна добавления сотрудника:
